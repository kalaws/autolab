# Kopiera filen till secrets.yml och fyll i riktiga värden.
# secrets.yml är gitignored och måste skapas manuellt för att sedan automatiskt kopieras till ansible-noden.

dockerhub_username: ""
dockerhub_token: ""

# Dessa skrivs till HashiCorp Vault under terraform apply --limit vault.
# Varje top-level key blir en mapp under secret/ i Vault.
vault_secrets:
  dockerhub:
    username: "{{ dockerhub_username }}"
    token: "{{ dockerhub_token }}"
