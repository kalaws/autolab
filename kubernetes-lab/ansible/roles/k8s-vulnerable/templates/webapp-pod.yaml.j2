apiVersion: apps/v1
kind: Deployment
metadata:
  name: webapp
  namespace: default
spec:
  replicas: 5
  selector:
    matchLabels:
      app: webapp
  template:
    metadata:
      labels:
        app: webapp
    spec:
      serviceAccountName: vulnerable-sa
      containers:
      - name: webapp
        image: "{{ webapp_dockerhub_image }}"
        ports:
        - containerPort: 5000
        env:
        - name: DB_PASSWORD
          value: "SuperHemligt123!"
        - name: API_KEY
          value: "sk-prod-abc123xyz789"
